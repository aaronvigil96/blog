extends ../layout/index

block contents
    h1 #{title}
    form(action="/api/v1/auth/register" method="POST")
        div
            label(for="name") Nombre:
            input(type="text" name="name" id="name" placeholder="Pedrito Pistolero")
        div
            label(for="email") Email:
            input(type="email" name="email" id="email" placeholder="correo@correo.com")
        div
            label(for="password") Contraseña:
            input(type="password" name="password" id="password" placeholder="!Soyunpassword1")
        button(type="submit") Registrarme
            